{
  "expo": {
    "name": "H-Auto",
    "slug": "h-auto-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hautomobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hauto.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "H-Auto uses the camera to take photos for your plot observations."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "H-Auto needs access to your photos so you can attach images to observations.",
          "cameraPermission": "H-Auto uses the camera to take photos for your plot observations."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "H-Auto tags your plot observations with your current location."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "H-Auto uses Face ID to quickly and securely unlock the app."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#16a34a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "970d4bf1-5467-4b8e-b80d-d7bd6adadad7"
      }
    }
  }
}
